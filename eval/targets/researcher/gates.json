{
  "target": "researcher",
  "rubric_version": "1.0.0",
  "gates": [
    {
      "name": "state_active_phase",
      "type": "file_contains",
      "file": "research/STATE.md",
      "pattern": "Active phase:",
      "feeds": "State Integrity"
    },
    {
      "name": "draft_methodology_section",
      "type": "file_contains",
      "file": "research/drafts/04-test-section.md",
      "pattern": "## Methodology & Limitations",
      "feeds": "Traceability",
      "na_for_entries": ["audit", "process-source", "cross-ref", "check-gaps"]
    }
  ],
  "content_lint": [
    {
      "name": "draft_no_placeholders",
      "file": "research/drafts/04-test-section.md",
      "forbid": "\\[(TODO|TBD|placeholder|FILL)\\b",
      "feeds": "Traceability",
      "optional_file": true
    },
    {
      "name": "output_no_placeholders",
      "file": "research/outputs/04-test-section.md",
      "forbid": "\\[(TODO|TBD|placeholder|FILL)\\b",
      "feeds": "Traceability",
      "optional_file": true
    }
  ]
}
